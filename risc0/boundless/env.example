# Boundless Workflow - Environment Variables
# Copy this file to .env and fill in your values:
#   cp env.example .env

# =============================================================================
# Required
# =============================================================================

# Wallet private key (Sepolia testnet)
# Create with: cast wallet new
# Fund with Sepolia ETH: https://faucets.chain.link/sepolia
export BOUNDLESS_WALLET_KEY=0x...
# Note your wallet address here for easy copy-paste into faucets:
# WALLET_ADDRESS=0x... (run: cast wallet address $BOUNDLESS_WALLET_KEY)

# Pinata JWT token for IPFS uploads (free tier is sufficient)
# Get from: https://app.pinata.cloud/developers/api-keys
export PINATA_JWT=eyJ...

# =============================================================================
# Optional (defaults shown)
# =============================================================================

# Ethereum RPC URL (Sepolia testnet)
# export ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Step log size in machine cycles (default: 100)
# export STEP_LOG_MCYCLES=100

# Proof pricing (reverse Dutch auction, in ETH)
# export MIN_PRICE_ETH=0.001
# export MAX_PRICE_ETH=0.01

# Request timeout in seconds (default: 1 hour)
# export TIMEOUT=3600

# Price ramp-up period in seconds (default: 5 minutes)
# export RAMP_UP_PERIOD=300
