# Cartesi RISC0 Groth16 Integration Test
#
# Verifies that Groth16 proofs generated by cartesi-risc0-cli pass the real
# RISC Zero verifier router on a Sepolia fork.
#
# Requirements: forge (Foundry), cartesi-risc0-cli, cartesi-machine.lua, Docker

ETH_RPC_URL  ?= https://ethereum-sepolia-rpc.publicnode.com
FIXTURES_DIR     := test/fixtures

LUA_BIN          ?= lua5.4
LUA              ?= $(LUA_BIN)
STEP_LOG_UTIL    := $(abspath ../step-log-util.lua)
CARTESI_RISC0_CLI ?= $(abspath ../rust/target/debug/cartesi-risc0-cli)
CARTESI_MACHINE  ?= cartesi-machine.lua

STEP_LOG         ?= $(FIXTURES_DIR)/step.log

.PHONY: dep build test step-log step-log-info image-id clean help

help:
	@echo "Groth16 Integration Test"
	@echo ""
	@echo "  make step-log                        Generate a step log for testing"
	@echo "  make step-log-info                   Display step log header values"
	@echo "  make fixtures                        Generate Groth16 seal + journal"
	@echo "  make test                            Run integration tests (Sepolia fork)"
	@echo "  make dep                             Install Foundry dependencies"
	@echo "  make clean                           Remove build artifacts and fixtures"

# ── Dependencies ─────────────────────────────────────────────
dep:
	@if [ ! -d lib/risc0-ethereum ]; then \
		forge install risc0/risc0-ethereum --no-commit; \
	else \
		echo "Dependencies already installed (lib/risc0-ethereum exists)"; \
	fi

# ── Step Log ─────────────────────────────────────────────────

STEP_LOG_MCYCLES ?= 1

step-log: $(FIXTURES_DIR)/step.log

$(FIXTURES_DIR)/step.log:
	@mkdir -p $(FIXTURES_DIR)
	@echo "Generating step log ($(STEP_LOG_MCYCLES) mcycle)..."
	$(CARTESI_MACHINE) \
		--hash-tree=hash_function:sha256 \
		--max-mcycle=0 \
		--log-step=$(STEP_LOG_MCYCLES),$@

step-log-info:
	@test -f "$(STEP_LOG)" || { echo "Error: $(STEP_LOG) not found. Run 'make step-log' first."; exit 1; }
	@$(LUA) $(STEP_LOG_UTIL) info $(STEP_LOG)

# ── Test Fixtures ────────────────────────────────────────────
# Generate a Groth16 seal and journal from a step log.
# Header values are extracted automatically from the step log.
# Requires: Docker running, RISC0_DEV_MODE=0

fixtures: $(FIXTURES_DIR)/seal.bin

$(FIXTURES_DIR)/seal.bin: $(STEP_LOG)
	$(eval HASH_BEFORE := $(shell $(LUA) $(STEP_LOG_UTIL) root-hash-before $(STEP_LOG)))
	$(eval MCYCLE_COUNT := $(shell $(LUA) $(STEP_LOG_UTIL) mcycle-count $(STEP_LOG)))
	$(eval HASH_AFTER := $(shell $(LUA) $(STEP_LOG_UTIL) root-hash-after $(STEP_LOG)))
	@$(LUA) $(STEP_LOG_UTIL) info $(STEP_LOG)
	RISC0_DEV_MODE=0 $(CARTESI_RISC0_CLI) prove-groth16 \
		"$(HASH_BEFORE)" $(STEP_LOG) "$(MCYCLE_COUNT)" "$(HASH_AFTER)" \
		$(FIXTURES_DIR)/seal.bin $(FIXTURES_DIR)/journal.bin
	@echo ""
	@echo "Fixtures ready:"
	@ls -l $(FIXTURES_DIR)/seal.bin $(FIXTURES_DIR)/journal.bin

#  --- Image ID ---
# Generate src/ImageID.sol from the guest binary's Image ID.
# The canonical Image ID requires a reproducible build (the default).
# A native build (RISC0_REPRODUCIBLE_BUILD=0) will produce a different Image ID.
# Requires: cartesi-risc0-cli built (make -C risc0)

src/ImageID.sol:
	$(eval IMAGE_ID := $(shell $(MAKE) -s -C .. image-id))
	@echo "// This file is auto-generated by \`make image-id\` and should not be modified." > $@
	@echo "// SPDX-License-Identifier: LGPL-3.0-or-later" >> $@
	@echo "pragma solidity ^0.8.20;" >> $@
	@echo "" >> $@
	@echo "library ImageID {" >> $@
	@echo "    bytes32 public constant CARTESI_STEP_VERIFIER_ID =" >> $@
	@echo "        bytes32(0x$(IMAGE_ID));" >> $@
	@echo "}" >> $@
	@echo "Generated src/ImageID.sol (Image ID: $(IMAGE_ID))"

image-id:
	@rm -f src/ImageID.sol
	@$(MAKE) src/ImageID.sol

# ── Build & Test ─────────────────────────────────────────────
build: dep
	forge build

test: dep src/ImageID.sol fixtures
	forge test --fork-url $(ETH_RPC_URL) -vvv

clean:
	forge clean
	rm -rf cache $(FIXTURES_DIR)
	rm -f src/ImageID.sol
